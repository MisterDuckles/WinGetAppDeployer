<Window x:Class="WingetAppDeployer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="WinApp Installer"
        Height="700"
        Width="1000"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="70"/>
            <!-- Footer/Actions -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🪟" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="WinApp Installer" FontSize="24" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox Width="250" Margin="0,0,15,0"
                             x:Name="SearchBox"
                             TextChanged="SearchBox_TextChanged"
                             Padding="10,8"
                             Background="White"
                             Foreground="#212121"/>
                    <Button Content="⚙️" FontSize="20" Width="40" Height="40"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="SettingsButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel x:Name="ContentPanel">
                <!-- Welcome message (shown on first run) -->
                <Border x:Name="WelcomeBanner"
                        Background="#2196F3"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="👋 Welcome to WinApp Installer!"
                                     FontSize="20"
                                     FontWeight="Bold"
                                     Foreground="White"/>
                            <TextBlock Text="Quickly install your favorite applications using Winget. Select apps below and click Install."
                                     FontSize="14"
                                     Foreground="White"
                                     Margin="0,5,0,0"
                                     TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Content="✕"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White"
                                Click="CloseWelcome_Click"/>
                    </Grid>
                </Border>

                <!-- Loading indicator -->
                <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0"
                                 IsIndeterminate="True"
                                 Width="60"
                                 Height="60"/>
                    <TextBlock Text="Loading apps..."
                               FontSize="16"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"
                               Foreground="#757575"/>
                </StackPanel>

                <!-- Apps will be loaded here dynamically -->
                <StackPanel x:Name="AppsPanel" Visibility="Collapsed">
                    <!-- Categories will be added programmatically -->
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer / Action Bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SelectionCountText"
                               Text="0 apps selected"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Foreground="#757575"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="InstallButton"
                            Content="Install Selected Apps"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="45"
                            Padding="30,0"
                            FontSize="14"
                            Click="InstallButton_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
