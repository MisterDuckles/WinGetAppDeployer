<Window x:Class="WinAppInstaller.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="500"
        Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="⚙️ Settings"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Appearance -->
                <Border Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🎨 Appearance"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,15"/>

                        <TextBlock Text="Theme:" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ThemeComboBox"
                                  Margin="0,0,0,15"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem Content="Minimal (Default)" Tag="Minimal"/>
                            <ComboBoxItem Content="Fluent (Windows 11)" Tag="Fluent"/>
                            <ComboBoxItem Content="Material Design" Tag="Material"/>
                        </ComboBox>

                        <CheckBox x:Name="DarkModeCheckBox"
                                  Content="Dark Mode (Coming Soon)"
                                  IsEnabled="False"
                                  Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Updates -->
                <Border Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20"
                        Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🔄 Updates"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,15"/>

                        <CheckBox x:Name="CheckUpdatesOnStartupCheckBox"
                                  Content="Check for app updates on startup"
                                  Margin="0,0,0,10"/>

                        <Button Content="Manage Auto-Update Schedule"
                                Width="200"
                                HorizontalAlignment="Left"
                                Click="ManageScheduleButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- General -->
                <Border Background="White"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="📋 General"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,15"/>

                        <CheckBox x:Name="ShowWelcomeCheckBox"
                                  Content="Show welcome message on startup"
                                  Margin="0,0,0,10"/>

<TextBlock Text="About"
                                   FontWeight="SemiBold"
                                   Margin="0,15,0,5"/>
                        <TextBlock Text="WinApp Installer v1.0.0"
                                   FontSize="12"
                                   Foreground="#757575"/>
                        <TextBlock Text="A modern app installer for Windows using Winget"
                                   FontSize="12"
                                   Foreground="#757575"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Cancel"
                    Width="100"
                    Height="40"
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Save"
                    Width="100"
                    Height="40"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
